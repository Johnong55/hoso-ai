# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="Admin Procedure AI"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT=development          # development | staging | production

# ── API ───────────────────────────────────────────────────────────────────────
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=admin_ai_user
DB_PASSWORD=your_strong_password
DB_NAME=admin_procedure_ai
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Qdrant ───────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=procedure_chunks
# Leave QDRANT_PERSIST_DIR non-empty for local/embedded mode (no Docker needed).
# Set it to "" to use the Docker/remote server at QDRANT_HOST:QDRANT_PORT instead.
QDRANT_PERSIST_DIR=./qdrant_data

# ── LLM — OpenRouter ──────────────────────────────────────────────────────────
# Lấy API key tại: https://openrouter.ai/keys
LLM_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=qwen/qwen3-6b:free
LLM_MAX_TOKENS=1500
LLM_TEMPERATURE=0.1

# ── Embedding — Gemini ────────────────────────────────────────────────────────
# Lấy API key tại: https://aistudio.google.com/app/apikey (free tier)
GEMINI_API_KEY=your-gemini-api-key
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSIONS=3072
# Tuỳ chọn giảm dims (MRL truncation) để tiết kiệm dung lượng vector:
# EMBEDDING_DIMENSIONS=1536
# EMBEDDING_DIMENSIONS=768
# Model legacy (768 dims):
# EMBEDDING_MODEL=text-embedding-004
# EMBEDDING_DIMENSIONS=768

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your_very_secret_key_change_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── RAG ───────────────────────────────────────────────────────────────────────
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.35
RAG_MAX_CONTEXT_CHUNKS=8
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64

# ── Crawler ───────────────────────────────────────────────────────────────────
CRAWLER_DELAY_MIN=1.5            # seconds between requests (min)
CRAWLER_DELAY_MAX=3.5            # seconds between requests (max)
CRAWLER_MAX_RETRIES=3
CRAWLER_TIMEOUT=30               # seconds per page
CRAWL_SCHEDULE_HOUR=2            # daily crawl hour (24h)
CRAWL_SCHEDULE_MINUTE=0
# Thư mục chứa các file .xlsx danh sách thủ tục (1 file/bộ-ngành).
# Code đọc cột "Mã TTHC" từ mỗi file, rồi gọi rest.jsp + export_word_detail_tthc.jsp
# để tải file Word chi tiết của từng thủ tục.
XLSX_DATA_DIR=./data/tthc
XLSX_CRAWL_CONCURRENCY=5         # số request song song khi crawl theo danh sách
