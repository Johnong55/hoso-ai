# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="Admin Procedure AI"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT=development          # development | staging | production

# ── API ───────────────────────────────────────────────────────────────────────
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=admin_ai_user
DB_PASSWORD=your_strong_password
DB_NAME=admin_procedure_ai
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION_NAME=procedure_chunks
# Set CHROMA_PERSIST_DIR for local (non-server) mode:
CHROMA_PERSIST_DIR=./chroma_data

# ── LLM — OpenRouter ──────────────────────────────────────────────────────────
# Lấy API key tại: https://openrouter.ai/keys
LLM_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=qwen/qwen3-6b:free
LLM_MAX_TOKENS=1500
LLM_TEMPERATURE=0.1

# ── Embedding — Cohere ────────────────────────────────────────────────────────
# Lấy API key tại: https://dashboard.cohere.com/api-keys (free trial)
COHERE_API_KEY=your-cohere-api-key
EMBEDDING_MODEL=embed-multilingual-v3.0
EMBEDDING_DIMENSIONS=1024
# Tuỳ chọn nhanh hơn (384 dims, ít chính xác hơn):
# EMBEDDING_MODEL=embed-multilingual-light-v3.0
# EMBEDDING_DIMENSIONS=384

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your_very_secret_key_change_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── RAG ───────────────────────────────────────────────────────────────────────
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.35
RAG_MAX_CONTEXT_CHUNKS=8
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64

# ── Crawler ───────────────────────────────────────────────────────────────────
CRAWLER_DELAY_MIN=1.5            # seconds between requests (min)
CRAWLER_DELAY_MAX=3.5            # seconds between requests (max)
CRAWLER_MAX_RETRIES=3
CRAWLER_TIMEOUT=30               # seconds per page
CRAWL_SCHEDULE_HOUR=2            # daily crawl hour (24h)
CRAWL_SCHEDULE_MINUTE=0
