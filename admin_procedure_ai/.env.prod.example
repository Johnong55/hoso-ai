# Production env — COPY thành .env.prod trên VPS, ĐỪNG commit file thật vào git.
# Generate secrets bằng: openssl rand -hex 32

# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME="HoSoAI"
DEBUG=false
ENVIRONMENT=production

# CORS — chỉ cho phép domain frontend của bạn
ALLOWED_ORIGINS=https://hosoai.com,https://www.hosoai.com

# ── Database (internal Docker) ───────────────────────────────────────────────
DB_HOST=db
DB_PORT=3306
DB_NAME=admin_procedure_ai
DB_USER=admin_ai_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Qdrant Cloud ─────────────────────────────────────────────────────────────
QDRANT_PERSIST_DIR=
QDRANT_HOST=your-cluster.qdrant.io
QDRANT_PORT=6333
QDRANT_API_KEY=your-qdrant-cloud-api-key
QDRANT_COLLECTION_NAME=procedure_chunks
QDRANT_USE_HTTPS=true

# ── LLM (Cloudflare Workers AI — nhanh + free tier) ─────────────────────────
LLM_PROVIDER=cloudflare
CLOUDFLARE_LLM_MODEL=@cf/meta/llama-3.3-70b-instruct-fp8-fast
LLM_MAX_TOKENS=4000
LLM_TEMPERATURE=0.1

# ── Embedding (Cloudflare) ──────────────────────────────────────────────────
EMBEDDING_PROVIDER=cloudflare
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token
CLOUDFLARE_EMBEDDING_MODEL=@cf/baai/bge-m3
CLOUDFLARE_EMBEDDING_DIMENSIONS=1024
EMBEDDING_MIN_INTERVAL_SEC=0

# ── Crawler ──────────────────────────────────────────────────────────────────
CRAWLER_TIMEOUT=30
DVCQG_CRAWL_CONCURRENCY=3

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
