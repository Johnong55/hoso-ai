# ── Application ──────────────────────────────────────────────────────────────
APP_NAME="Admin Procedure AI"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT=development          # development | staging | production

# ── API ───────────────────────────────────────────────────────────────────────
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=admin_ai_user
DB_PASSWORD=your_strong_password
DB_NAME=admin_procedure_ai
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION_NAME=procedure_chunks
# Set CHROMA_PERSIST_DIR for local (non-server) mode:
CHROMA_PERSIST_DIR=./chroma_data

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MAX_TOKENS=1500
OPENAI_TEMPERATURE=0.1

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your_very_secret_key_change_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── RAG ───────────────────────────────────────────────────────────────────────
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.35
RAG_MAX_CONTEXT_CHUNKS=8
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64

# ── Crawler ───────────────────────────────────────────────────────────────────
CRAWLER_DELAY_MIN=1.5            # seconds between requests (min)
CRAWLER_DELAY_MAX=3.5            # seconds between requests (max)
CRAWLER_MAX_RETRIES=3
CRAWLER_TIMEOUT=30               # seconds per page
CRAWL_SCHEDULE_HOUR=2            # daily crawl hour (24h)
CRAWL_SCHEDULE_MINUTE=0
